def request_videos_batch(
    api_key: str,
    video_ids: List[str],
    session: Optional[requests.Session] = None,
) -> Dict:
    """
    videos.list API를 호출합니다.
    snippet + contentDetails + statistics 수집.
    """
    params = {
        "key":        api_key,
        "part":       "snippet,contentDetails,statistics",
        "id":         ",".join(video_ids),
        "maxResults": len(video_ids),
    }
    requester = session or requests
    response  = requester.get(API_URL, params=params, timeout=30)
    response.raise_for_status()
    return response.json()


# ═══════════════════════════════════════════════════════════════
# 응답 파싱
# ═══════════════════════════════════════════════════════════════

def parse_duration(duration: str) -> Optional[int]:
    if not duration:
        return None
    pattern = re.compile(
        r"^P(?:(?P<days>\d+)D)?"
        r"(?:T(?:(?P<hours>\d+)H)?(?:(?P<minutes>\d+)M)?(?:(?P<seconds>\d+)S)?)?$"
    )
    m = pattern.match(duration)
    if not m:
        return None
    p = m.groupdict(default="0")
    return (int(p["days"])*86400 + int(p["hours"])*3600 +
            int(p["minutes"])*60 + int(p["seconds"]))


def parse_video_items(
    items: List[Dict],
    channel_map: Dict[str, str],
) -> List[Dict]:
    """
    videos.list 응답을 파싱합니다.

    channel_map:
      04_channel_uploads.csv에서 가져온 video_id → channel_id 매핑
      API 응답의 channelId보다 이 값을 우선합니다.
      (업로드 플레이리스트 기준 channel_id가 더 정확)
    """
    collected_at_utc = datetime.now(timezone.utc).isoformat()
    rows: List[Dict] = []

    for item in items:
        video_id        = item.get("id", "")
        snippet         = item.get("snippet", {}) or {}
        content_details = item.get("contentDetails", {}) or {}
        statistics      = item.get("statistics", {}) or {}

        published_at = snippet.get("publishedAt", "")
        title        = snippet.get("title", "")
        description  = snippet.get("description", "")
        tags_list    = snippet.get("tags", []) or []
        tags         = " | ".join(str(t) for t in tags_list)

        duration_sec = parse_duration(content_details.get("duration", ""))
        view_count   = int(statistics.get("viewCount", 0) or 0)
        like_count   = int(statistics.get("likeCount", 0) or 0)

        is_ai_cover        = classify_ai_cover(title, description, tags)
        week_start_date    = get_week_start_date(published_at)
        weeks_from_policy1 = get_weeks_from_policy(published_at, POLICY1_DATE)
        weeks_from_policy2 = get_weeks_from_policy(published_at, POLICY2_DATE)

        # channel_id: 업로드 플레이리스트 기준 우선
        channel_id = channel_map.get(video_id, snippet.get("channelId", ""))

        rows.append({
            "video_id":            video_id,
            "channel_id":          channel_id,
            "published_at":        published_at,
            "video_title":         title,
            "video_description":   description,
            "video_tags":          tags,
            "duration_sec":        duration_sec,
            "view_count":          view_count,
            "like_count":          like_count,
            "is_ai_cover":         is_ai_cover,
            "week_start_date":     week_start_date,
            "weeks_from_policy1":  weeks_from_policy1,
            "weeks_from_policy2":  weeks_from_policy2,
            "collected_at_utc":    collected_at_utc,
        })

    return rows


# ═══════════════════════════════════════════════════════════════
# CSV 저장
# ═══════════════════════════════════════════════════════════════

def append_rows(output_path: str, rows: List[Dict]) -> int:
    if not rows:
        return 0
    with open(output_path, "a", encoding="utf-8-sig", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=OUTPUT_COLUMNS)
        writer.writerows(rows)
    return len(rows)


# ═══════════════════════════════════════════════════════════════
# 쿼터 초과 감지
# ═══════════════════════════════════════════════════════════════

def is_quota_exceeded(exc: requests.HTTPError) -> bool:
    try:
        text = exc.response.text.lower()
    except Exception:
        text = str(exc).lower()
    return "quotaexceeded" in text


# ═══════════════════════════════════════════════════════════════
# 배치 생성
# ═══════════════════════════════════════════════════════════════

def make_batches(items: List[str], batch_size: int) -> List[List[str]]:
    return [items[i:i+batch_size] for i in range(0, len(items), batch_size)]


# ═══════════════════════════════════════════════════════════════
# 메인 실행
# ═══════════════════════════════════════════════════════════════

def main() -> None:
    args = parse_args()
    validate_args(args)

    if args.reset:
        print("\n[RESET] 기존 파일을 삭제하고 처음부터 수집합니다.")
        reset_output_files(args.output, args.completed)

    # 수집 대상 video_id 로드
    new_ids, channel_map = load_target_video_ids(
        args.input_uploads,
        args.input_existing,
    )

    if not new_ids:
        print("\n[DONE] 수집할 신규 video_id가 없습니다.")
        print("모든 영상이 이미 수집되어 있습니다.")
        return

    batches       = make_batches(new_ids, BATCH_SIZE)
    total_batches = len(batches)

    # 완료된 배치 로드
    completed_batches = load_completed_batches(args.completed)

    # CSV 헤더 초기화
    ensure_csv_header(args.output)

    pending_count = total_batches - len(completed_batches)

    print(f"\n{'═'*65}")
    print(f"  채널 업로드 메타데이터 수집 (videos.list)")
    print(f"{'═'*65}")
    print(f"  신규 video_id 수     : {len(new_ids):,}개")
    print(f"  총 배치 수           : {total_batches:,}개 (배치당 {BATCH_SIZE}개)")
    print(f"  이미 완료된 배치     : {len(completed_batches):,}개 → 건너뜀")
    print(f"  이번에 수집할 배치   : {pending_count:,}개")
    print(f"  예상 쿼터 소모       : {pending_count:,} units")
    print(f"  입력 파일 (업로드)   : {args.input_uploads}")
    print(f"  입력 파일 (기존)     : {args.input_existing}")
    print(f"  출력 파일            : {args.output}")
    print(f"  완료 기록 파일       : {args.completed}")
    print(f"{'═'*65}\n")

    # 수집 통계
    total_requests  = 0
    total_saved     = 0
    total_missing   = 0
    batches_skipped = 0
    batches_done    = 0
    batches_error   = 0
    ai_cover_count  = 0

    session = requests.Session()

    try:
        for batch_idx, batch_ids in enumerate(batches):

            # ─────────────────────────────────────────────────
            # 완료된 배치 건너뛰기 (API 요청 없음)
            # ─────────────────────────────────────────────────
            if batch_idx in completed_batches:
                batches_skipped += 1
                if batch_idx % 200 == 0:
                    print(f"[BATCH {batch_idx+1:5d}/{total_batches}] ... (건너뜀)")
                continue

            batch_error = False

            try:
                data = request_videos_batch(
                    api_key    = args.api_key,
                    video_ids  = batch_ids,
                    session    = session,
                )
                total_requests += 1

            except requests.HTTPError as exc:
                status = getattr(exc.response, "status_code", "unknown")
                print(f"[BATCH {batch_idx+1:5d}] [ERROR] HTTP {status}")

                if is_quota_exceeded(exc):
                    print(
                        "\n  [STOP] ❌ 쿼터 초과. 즉시 중단합니다.\n"
                        "  내일 다시 실행하면 이 배치부터 이어서 수집됩니다."
                    )
                    raise

                batch_error = True

            except requests.RequestException as exc:
                print(f"[BATCH {batch_idx+1:5d}] [ERROR] {exc}")
                batch_error = True

            if batch_error:
                batches_error += 1
                time.sleep(args.sleep_seconds)
                continue

            # ─────────────────────────────────────────────────
            # 응답 파싱 및 저장
            # ─────────────────────────────────────────────────
            items        = data.get("items", [])
            returned_ids = {item.get("id", "") for item in items}
            missing_ids  = [vid for vid in batch_ids if vid not in returned_ids]
            total_missing += len(missing_ids)

            rows  = parse_video_items(items, channel_map)
            saved = append_rows(args.output, rows)
            total_saved    += saved
            ai_cover_count += sum(1 for r in rows if r["is_ai_cover"] == 1)

            # 500배치마다 진행상황 출력
            if (batch_idx + 1) % 500 == 0 or batch_idx < 3:
                print(
                    f"[BATCH {batch_idx+1:5d}/{total_batches}] "
                    f"saved={saved:3d} "
                    f"missing={len(missing_ids):2d} "
                    f"ai_cover={sum(1 for r in rows if r['is_ai_cover']==1):3d} "
                    f"| 누적 {total_saved:,}개"
                )

            # ─────────────────────────────────────────────────
            # 배치 완료 기록
            # ─────────────────────────────────────────────────
            mark_batch_completed(args.completed, batch_idx)
            completed_batches.add(batch_idx)
            batches_done += 1

            time.sleep(args.sleep_seconds)

    except requests.HTTPError:
        pass

    finally:
        session.close()

    # ─────────────────────────────────────────────────────────
    # 최종 결과 출력
    # ─────────────────────────────────────────────────────────
    total_classified = total_saved
    ai_rate = ai_cover_count / total_classified * 100 if total_classified > 0 else 0

    print(f"\n{'═'*65}")
    print(f"  수집 결과")
    print(f"{'═'*65}")
    print(f"  총 API 요청 수          : {total_requests:,}회")
    print(f"  총 저장 행 수           : {total_saved:,}개")
    print(f"  API 미반환 영상         : {total_missing:,}개 (삭제/비공개 등)")
    print(f"  건너뛴 배치             : {batches_skipped:,}개 (이미 완료)")
    print(f"  이번에 완료된 배치      : {batches_done:,}개")
    print(f"  에러 배치               : {batches_error:,}개")
    print(f"─{'─'*64}")
    print(f"  is_ai_cover=1 (표본)    : {ai_cover_count:,}개 ({ai_rate:.1f}%)")
    print(f"  is_ai_cover=0 (비표본)  : {total_saved-ai_cover_count:,}개")
    print(f"  출력 파일               : {args.output}")
    print(f"{'═'*65}")

    remaining = total_batches - batches_skipped - batches_done
    if remaining > 0:
        print(
            f"\n  ⚠️  아직 {remaining}개 배치가 남아있습니다.\n"
            "  다시 실행하면 이어서 수집됩니다."
        )
    else:
        print(
            "\n  🎉 모든 배치 수집 완료!\n"
            "\n  이제 분석에 필요한 모든 데이터가 준비됐습니다."
            "\n"
            "\n  분석에 사용할 파일:"
            "\n    data/02_videos_meta.csv   → 표본 영상 메타데이터"
            "\n    data/03_channels_meta.csv → 채널 메타데이터 (생성일 등)"
            "\n    data/05_uploads_meta.csv  → 채널 전체 업로드 메타데이터"
            "\n"
            "\n  계산 가능한 핵심 지표:"
            "\n    - 채널별 정책 전/후 AI Cover 업로드 수 변화"
            "\n    - 채널 생존율 / 이탈율 / 전환율"
            "\n    - heavy uploader 채널의 행동 변화"
            "\n    - 풍선효과: 기존채널 감소 + 신규채널 증가 패턴\n"
        )


