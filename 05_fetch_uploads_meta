def reset_output_files(output_path: str, completed_path: str) -> None:
    for path in [output_path, completed_path]:
        if os.path.exists(path):
            os.remove(path)
            print(f"[RESET] 삭제됨: {path}")


def ensure_csv_header(output_path: str) -> None:
    if os.path.exists(output_path):
        return
    os.makedirs(os.path.dirname(output_path), exist_ok=True) if os.path.dirname(output_path) else None
    with open(output_path, "w", encoding="utf-8-sig", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=OUTPUT_COLUMNS)
        writer.writeheader()


# ═══════════════════════════════════════════════════════════════
# AI Cover 분류
# ═══════════════════════════════════════════════════════════════

def classify_ai_cover(title: object, description: object, tags: object) -> int:
    """
    02_reclassify_ai_cover.py와 완전히 동일한 분류 로직.

    Step 1. title(소문자)에 EXCLUDE 신호가 있으면 → 0
            (description/tags의 'news', 'guide' 등은 무시)
    Step 2. title + description + tags 전체(소문자)에서
            INCLUDE 정규식 패턴 매칭 → 1
    Step 3. INCLUDE 단순 문자열 포함 → 1
    Step 4. 모두 해당 없으면 → 0

    대소문자 무관 (.lower() 처리)
    """
    title_lower    = str(title).lower() if pd.notna(title) else ""
    combined_lower = (
        f"{title_lower} "
        f"{str(description).lower() if pd.notna(description) else ''} "
        f"{str(tags).lower() if pd.notna(tags) else ''}"
    )

    # Step 1: EXCLUDE (title에만)
    for signal in EXCLUDE_SIGNALS_TITLE_ONLY:
        if signal in title_lower:
            return 0

    # Step 2: 정규식 패턴 (전체 텍스트, 대소문자 무관)
    for pattern in INCLUDE_PATTERNS_REGEX:
        if re.search(pattern, combined_lower):
            return 1

    # Step 3: 단순 문자열 포함 (전체 텍스트)
    for signal in INCLUDE_STRINGS:
        if signal in combined_lower:
            return 1

    return 0


