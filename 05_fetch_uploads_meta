def get_week_start_date(published_at: str) -> str:
    try:
        dt = datetime.fromisoformat(published_at.replace("Z", "+00:00"))
        week_start = dt - timedelta(days=dt.weekday())
        return week_start.strftime("%Y-%m-%d")
    except Exception:
        return ""


def get_weeks_from_policy(published_at: str, policy_date: datetime) -> Optional[float]:
    try:
        dt = datetime.fromisoformat(published_at.replace("Z", "+00:00"))
        return round((dt - policy_date).days / 7, 2)
    except Exception:
        return None


