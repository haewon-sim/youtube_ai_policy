def load_target_video_ids(
    uploads_path: str,
    existing_path: str,
) -> List[str]:
    """
    수집할 video_id 목록을 준비합니다.

    04_channel_uploads.csv의 video_id 중에서
    02_videos_meta.csv에 이미 있는 video_id를 제외합니다.

    이미 있는 영상은 메타데이터가 있으므로 재수집 불필요 → 쿼터 절약
    """
    uploads_df = pd.read_csv(uploads_path, low_memory=False)
    all_ids    = set(uploads_df['video_id'].dropna().astype(str).str.strip())

    # 이미 수집된 video_id 로드
    existing_ids: Set[str] = set()
    if os.path.exists(existing_path):
        existing_df  = pd.read_csv(existing_path, low_memory=False,
                                   usecols=['video_id'])
        existing_ids = set(existing_df['video_id'].dropna().astype(str).str.strip())

    # 출력 파일에 이미 있는 video_id도 제외
    output_path = DEFAULT_OUTPUT
    if os.path.exists(output_path):
        out_df       = pd.read_csv(output_path, low_memory=False,
                                   usecols=['video_id'])
        existing_ids |= set(out_df['video_id'].dropna().astype(str).str.strip())

    new_ids = sorted(all_ids - existing_ids)

    print(f"[INFO] 채널 업로드 총 video_id  : {len(all_ids):,}")
    print(f"[INFO] 기존 수집 완료 video_id   : {len(existing_ids):,}")
    print(f"[INFO] 신규 수집 대상 video_id   : {len(new_ids):,}")

    # channel_id 매핑 보존
    channel_map = dict(zip(
        uploads_df['video_id'].astype(str).str.strip(),
        uploads_df['channel_id'].astype(str).str.strip()
    ))

    return new_ids, channel_map


