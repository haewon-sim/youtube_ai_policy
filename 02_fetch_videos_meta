def classify_ai_cover(
    title: str,
    description: str,
    tags: str,
) -> int:
    """
    영상이 실제 AI Cover 콘텐츠인지 규칙 기반으로 분류합니다.

    분류 로직:
      1. title + description + tags를 합쳐서 소문자로 변환
      2. EXCLUDE_SIGNALS(튜토리얼, 리뷰 등)가 있으면 0 반환
      3. INCLUDE_SIGNALS(rvc, voice clone 등)가 있으면 1 반환
      4. 둘 다 없으면 0 반환

    Returns:
      1: AI Cover 영상 (분석 표본에 포함)
      0: AI Cover 아님 (분석 표본에서 제외)
    """
    # 텍스트 통합 및 소문자 변환
    combined = f"{title} {description} {tags}".lower()

    # 제외 신호 먼저 확인 (튜토리얼, 리뷰 등은 AI Cover 콘텐츠가 아님)
    for signal in EXCLUDE_SIGNALS:
        if signal in combined:
            return 0

    # 포함 신호 확인
    for signal in INCLUDE_SIGNALS:
        if signal in combined:
            return 1

    return 0


