def load_completed_batches(filepath: str) -> Set[int]:
    """
    02_completed_batches.txt에서 완료된 배치 번호를 로드합니다.
    배치 번호 = 0부터 시작하는 정수 (배치 인덱스)

    완료된 배치는 API 요청 없이 건너뜁니다.
    API 키를 교체해도 이 파일은 유지됩니다.
    """
    completed: Set[int] = set()
    if not os.path.exists(filepath):
        return completed

    with open(filepath, "r", encoding="utf-8") as f:
        for line in f:
            val = line.strip()
            if val.isdigit():
                completed.add(int(val))

    return completed


def mark_batch_completed(filepath: str, batch_idx: int) -> None:
    """
    배치가 정상 완료됐을 때 배치 번호를 기록합니다.
    에러가 발생한 배치는 기록하지 않아 다음 실행 시 재수집됩니다.
    """
    with open(filepath, "a", encoding="utf-8") as f:
        f.write(f"{batch_idx}\n")


