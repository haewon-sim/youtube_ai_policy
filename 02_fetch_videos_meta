def get_week_start_date(published_at: str) -> str:
    """
    게시일 기준 ISO week 시작일(월요일)을 반환합니다.
    Event Study의 시간 축으로 사용됩니다.

    예시: "2024-03-20T12:00:00Z" → "2024-03-18" (해당 주 월요일)
    """
    try:
        dt = datetime.fromisoformat(published_at.replace("Z", "+00:00"))
        # 월요일(weekday=0) 기준 ISO week 시작일
        week_start = dt - timedelta(days=dt.weekday())
        return week_start.strftime("%Y-%m-%d")
    except Exception:
        return ""


def get_weeks_from_policy(published_at: str, policy_date: datetime) -> Optional[float]:
    """
    게시일 기준 정책 시점으로부터 몇 주 경과했는지 계산합니다.

    양수: 정책 이후 (post-policy)
    음수: 정책 이전 (pre-policy)
    0   : 정책 시행 주

    Event Study의 핵심 변수로 사용됩니다.
    """
    try:
        dt = datetime.fromisoformat(published_at.replace("Z", "+00:00"))
        delta_days = (dt - policy_date).days
        return round(delta_days / 7, 2)
    except Exception:
        return None


