def request_videos_batch(
    api_key: str,
    video_ids: List[str],
    session: Optional[requests.Session] = None,
) -> Dict:
    """
    videos.list API를 호출하여 영상 메타데이터를 수집합니다.

    수집 part:
      - snippet        : title, description, tags, publishedAt, channelId
      - contentDetails : duration
      - statistics     : viewCount, likeCount
    """
    params = {
        "key":        api_key,
        "part":       "snippet,contentDetails,statistics",
        "id":         ",".join(video_ids),
        "maxResults": len(video_ids),
    }

    requester = session or requests
    response  = requester.get(API_URL, params=params, timeout=30)
    response.raise_for_status()
    return response.json()


# ═══════════════════════════════════════════════════════════════
# 응답 파싱
# ═══════════════════════════════════════════════════════════════

def parse_video_items(
    items: List[Dict],
    seed_lookup: Dict[str, str],  # video_id → search_window_start
) -> List[Dict]:
    """
    videos.list 응답을 파싱하여 필요한 컬럼만 추출합니다.

    seed_lookup:
      01_seed_videos.csv에서 가져온 video_id → search_window_start 매핑
      provenance 정보로 CSV에 저장됩니다.
    """
    collected_at_utc = datetime.now(timezone.utc).isoformat()
    rows: List[Dict] = []

    for item in items:
        video_id         = item.get("id", "")
        snippet          = item.get("snippet", {}) or {}
        content_details  = item.get("contentDetails", {}) or {}
        statistics       = item.get("statistics", {}) or {}

        # 기본 메타데이터
        published_at = snippet.get("publishedAt", "")
        title        = snippet.get("title", "")
        description  = snippet.get("description", "")

        # tags는 리스트 → " | "로 join
        tags_list = snippet.get("tags", []) or []
        tags      = " | ".join(str(t) for t in tags_list)

        # duration → 초 변환
        duration_raw = content_details.get("duration", "")
        duration_sec = parse_duration_to_seconds(duration_raw)

        # 통계
        view_count = int(statistics.get("viewCount", 0) or 0)
        like_count = int(statistics.get("likeCount", 0) or 0)

        # AI Cover 분류
        is_ai_cover = classify_ai_cover(title, description, tags)

        # 주차 계산
        week_start_date    = get_week_start_date(published_at)
        weeks_from_policy1 = get_weeks_from_policy(published_at, POLICY1_DATE)
        weeks_from_policy2 = get_weeks_from_policy(published_at, POLICY2_DATE)

        rows.append({
            "video_id":            video_id,
            "channel_id":          snippet.get("channelId", ""),
            "published_at":        published_at,
            "video_title":         title,
            "video_description":   description,
            "video_tags":          tags,
            "duration_sec":        duration_sec,
            "view_count":          view_count,
            "like_count":          like_count,
            "is_ai_cover":         is_ai_cover,
            "week_start_date":     week_start_date,
            "weeks_from_policy1":  weeks_from_policy1,
            "weeks_from_policy2":  weeks_from_policy2,
            "search_window_start": seed_lookup.get(video_id, ""),
            "collected_at_utc":    collected_at_utc,
        })

    return rows


