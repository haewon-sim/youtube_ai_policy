    # reset 모드
    if args.reset:
        print("\n[RESET] 기존 파일을 삭제하고 처음부터 수집합니다.")
        reset_output_files(args.output, args.completed_batches)

    # ─────────────────────────────────────────────────────────
    # 입력 데이터 로드
    # ─────────────────────────────────────────────────────────
    seed_df = load_seed_videos(args.input)

    # video_id → search_window_start 매핑 (provenance 보존용)
    seed_lookup: Dict[str, str] = dict(
        zip(seed_df["video_id"], seed_df["search_window_start"])
    )

    # 수집할 video_id 목록 (정렬하여 배치 순서를 일정하게 유지)
    all_video_ids = sorted(seed_df["video_id"].tolist())
    batches       = make_batches(all_video_ids, BATCH_SIZE)
    total_batches = len(batches)

    # ─────────────────────────────────────────────────────────
    # 완료된 배치 로드
    # 이 집합에 있는 배치 번호는 API 요청 없이 건너뜁니다.
    # ─────────────────────────────────────────────────────────
    completed_batches = load_completed_batches(args.completed_batches)

    # CSV 헤더 초기화
    ensure_csv_header(args.output)

    pending_count = total_batches - len(completed_batches)

    print("\n" + "═" * 65)
    print("  영상 메타데이터 수집 (videos.list)")
    print("═" * 65)
    print(f"  총 고유 video_id     : {len(all_video_ids):,}개")
    print(f"  총 배치 수           : {total_batches:,}개 (배치당 {BATCH_SIZE}개)")
    print(f"  이미 완료된 배치     : {len(completed_batches):,}개 → 건너뜀")
    print(f"  이번에 수집할 배치   : {pending_count:,}개")
    print(f"  예상 쿼터 소모       : {pending_count:,} units (매우 저렴)")
    print(f"  입력 파일            : {args.input}")
    print(f"  출력 파일            : {args.output}")
    print(f"  완료 기록 파일       : {args.completed_batches}")
    print("═" * 65 + "\n")

    # 수집 통계
    total_requests   = 0
    total_saved      = 0
    total_missing    = 0  # API가 반환하지 않은 영상 (삭제/비공개 등)
    batches_skipped  = 0
    batches_done     = 0
    batches_error    = 0

    # AI Cover 분류 통계
    ai_cover_count   = 0
    non_cover_count  = 0

    session = requests.Session()

    try:
        for batch_idx, batch_ids in enumerate(batches):

            # ─────────────────────────────────────────────────
            # 완료된 배치 건너뛰기
            # API 요청 자체를 보내지 않습니다.
            # ─────────────────────────────────────────────────
            if batch_idx in completed_batches:
                batches_skipped += 1
                print(
                    f"[BATCH {batch_idx+1:4d}/{total_batches}] "
                    f"ids={len(batch_ids)} | ✅ SKIP"
                )
                continue

            print(
                f"[BATCH {batch_idx+1:4d}/{total_batches}] "
                f"ids={len(batch_ids)}"
            )

            batch_error = False

            try:
                data = request_videos_batch(
                    api_key    = args.api_key,
                    video_ids  = batch_ids,
                    session    = session,
                )
                total_requests += 1

            except requests.HTTPError as exc:
                status = getattr(exc.response, "status_code", "unknown")
                print(f"  [ERROR] HTTP {status}: {exc}")

                if is_quota_exceeded(exc):
                    print(
                        "\n  [STOP] ❌ 쿼터 초과 감지. 즉시 중단합니다.\n"
                        f"  현재 배치({batch_idx})는 완료 기록되지 않았으므로\n"
                        "  내일 다시 실행하면 이 배치부터 이어서 수집됩니다."
                    )
                    raise

                batch_error = True

            except requests.RequestException as exc:
                print(f"  [ERROR] 요청 실패: {exc}")
                batch_error = True

            if batch_error:
                batches_error += 1
                print(f"  → ⚠️  에러 발생 → 다음 실행 시 재수집")
                time.sleep(args.sleep_seconds)
                continue

            # ─────────────────────────────────────────────────
            # 응답 파싱 및 저장
            # ─────────────────────────────────────────────────
            items = data.get("items", [])

            # API가 반환하지 않은 영상 (삭제/비공개/지역 제한 등)
            returned_ids = {item.get("id", "") for item in items}
            missing_ids  = [vid for vid in batch_ids if vid not in returned_ids]
            total_missing += len(missing_ids)

            rows     = parse_video_items(items, seed_lookup)
            saved    = append_rows(args.output, rows)
            total_saved += saved

            # 분류 통계 업데이트
            for row in rows:
                if row["is_ai_cover"] == 1:
                    ai_cover_count += 1
                else:
                    non_cover_count += 1

            print(
                f"  returned={len(items):3d}  "
                f"saved={saved:3d}  "
                f"missing={len(missing_ids):2d}  "
                f"ai_cover={sum(1 for r in rows if r['is_ai_cover']==1):3d}"
            )

            if missing_ids:
                print(
                    f"  [참고] API 미반환 video_id "
                    f"(삭제/비공개/지역제한 등): {missing_ids[:5]}"
                    f"{'...' if len(missing_ids) > 5 else ''}"
                )

            # ─────────────────────────────────────────────────
            # 배치 완료 기록
            # 정상 완료된 배치만 기록합니다.
            # ─────────────────────────────────────────────────
            mark_batch_completed(args.completed_batches, batch_idx)
            completed_batches.add(batch_idx)
            batches_done += 1

            time.sleep(args.sleep_seconds)

    except requests.HTTPError:
        pass

    finally:
        session.close()

    # ─────────────────────────────────────────────────────────
    # 최종 결과 출력
    # ─────────────────────────────────────────────────────────
    total_classified = ai_cover_count + non_cover_count
    ai_cover_rate = (
        ai_cover_count / total_classified * 100
        if total_classified > 0 else 0
    )

    print("\n" + "═" * 65)
    print("  수집 결과")
    print("═" * 65)
    print(f"  총 API 요청 수         : {total_requests:,}회")
    print(f"  총 저장 행 수          : {total_saved:,}개")
    print(f"  API 미반환 영상        : {total_missing:,}개 (삭제/비공개 등)")
    print(f"  건너뛴 배치            : {batches_skipped:,}개 (이미 완료)")
    print(f"  이번에 완료된 배치     : {batches_done:,}개")
    print(f"  에러 배치              : {batches_error:,}개")
    print("─" * 65)
    print(f"  is_ai_cover=1 (분석 표본) : {ai_cover_count:,}개 ({ai_cover_rate:.1f}%)")
    print(f"  is_ai_cover=0 (제외)      : {non_cover_count:,}개")
    print(f"  출력 파일              : {args.output}")
    print(f"  완료 기록 파일         : {args.completed_batches}")
    print("═" * 65)

    remaining = total_batches - batches_skipped - batches_done
    if remaining > 0:
        print(
            f"\n  ⚠️  아직 {remaining}개 배치가 남아있습니다.\n"
            "  다시 실행하면 이어서 수집됩니다."
        )
    else:
        print(
            "\n  🎉 모든 배치 수집 완료!\n"
            "  다음 단계: python 03_fetch_channels_meta.py\n"
        )


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print(
            "\n[STOPPED] 사용자에 의해 중단되었습니다.\n"
            "현재 배치는 완료 기록되지 않았으므로\n"
            "다시 실행하면 해당 배치부터 이어서 수집됩니다."
        )
        sys.exit(1)
    except Exception as exc:
        print(f"\n[FATAL] 예상치 못한 오류: {exc}")
        sys.exit(1)
