def is_quota_exceeded(exc: requests.HTTPError) -> bool:
    try:
        text = exc.response.text.lower()
    except Exception:
        text = str(exc).lower()
    return "quotaexceeded" in text


# ═══════════════════════════════════════════════════════════════
# 배치 생성
# ═══════════════════════════════════════════════════════════════

def make_batches(
    video_ids: List[str],
    batch_size: int,
) -> List[List[str]]:
    """video_id 리스트를 batch_size 단위로 분할합니다."""
    return [
        video_ids[i:i + batch_size]
        for i in range(0, len(video_ids), batch_size)
    ]


