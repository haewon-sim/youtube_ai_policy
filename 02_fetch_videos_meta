def load_seed_videos(input_path: str) -> pd.DataFrame:
    """
    01_seed_videos.csv를 로드합니다.

    동일 video_id가 여러 윈도우에서 중복 수집됐을 수 있으므로
    video_id 기준으로 중복을 제거합니다.
    단, search_window_start는 첫 번째 값(가장 이른 윈도우)을 유지합니다.
    """
    df = pd.read_csv(input_path)

    print(f"[INFO] 입력 파일 총 행 수: {len(df):,}")

    # video_id 기준 중복 제거 (search_window_start는 첫 번째 값 유지)
    df = df.sort_values("search_window_start").drop_duplicates(
        subset=["video_id"], keep="first"
    ).reset_index(drop=True)

    print(f"[INFO] 중복 제거 후 고유 video_id 수: {len(df):,}")

    return df


